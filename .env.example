# Copie este arquivo para ".env" e ajuste os valores conforme o seu ambiente.

# String de conexão do banco de dados.
# MySQL (produção/uso real):
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/estoque_trailer

# Para rodar rapidamente sem instalar o MySQL, é possível usar SQLite:
# DATABASE_URL=sqlite:///./estoque.db
